{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "OmTeDoen",
  "version": "0.5.1",
  "identifier": "com.omtedoen.todo",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OmTeDoen",
        "width": 1100,
        "height": 700,
        "minWidth": 380,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "macOS": {
      "entitlements": "entitlements.mac.plist"
    },
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXkgNUNFQ0I1MTk0NkFCMDAwOQpSV1FKQUt0R0diWHNYQXhMSVc0enpqVldzOW1rNEdscUJDbWxrVUh3bEs1dUVYdUFPc0lTUE0vMQo=",
      "endpoints": [
        "https://github.com/geekrebel/omtedoen/releases/latest/download/latest.json"
      ]
    }
  }
}